{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "0"
  },
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(sqlite3:*)",
      "Bash(curl:127.0.0.1*)",
      "Bash(python3:*)",
      "Bash(node:*)",
      "Bash(git:*)",
      "Bash(tmux:*)",
      "Bash(systemctl --user:*)",
      "Bash(journalctl --user:*)",
      "Read(*)",
      "Write(~/.openclaw/workspace/*)",
      "Write(~/.openclaw/memory/*)",
      "Write(~/CLAUDE.md)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Write(~/.openclaw/openclaw.json)"
    ]
  }
}
